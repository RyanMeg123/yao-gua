generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model History {
  id             Int      @id @default(autoincrement())
  time           String
  question       String
  age            String
  gender         String
  tosses         Json
  interpretation String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("history")
}
